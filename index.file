// ─── KOORDINAT (lat, lng per id kasus) ───────────────────────────────────
const COORDS = {
  1:[-7.672,110.838], 2:[-3.954,103.082], 3:[-3.501,103.798],
  4:[-4.550,104.660], 5:[-5.389,105.262], 6:[-5.100,105.900],
  7:[-4.550,104.660], 8:[-7.810,110.920], 9:[-1.580,123.480],
  10:[-5.630,132.740],11:[-6.846,107.404],12:[-6.858,107.920],
  13:[-6.531,107.069],14:[-5.430,105.230],15:[-7.394,108.352],
  16:[-6.716,106.936],17:[-4.550,104.660],18:[-7.856,111.014],
  19:[-6.462,107.000],20:[2.577,99.084],  21:[1.308,97.538],
  22:[-5.722,105.561],23:[-7.902,111.091],24:[2.777,98.320],
  25:[-5.389,105.262],26:[0.452,97.830],  27:[3.000,97.580],
  28:[-8.126,113.220],29:[-7.257,112.752]
};
CASES.forEach(c => { if (COORDS[c.id]) { c.lat = COORDS[c.id][0]; c.lng = COORDS[c.id][1]; } });

// ─── STATE ────────────────────────────────────────────────────────────────
let currentView = 'card';
let sortField = 'tanggal';
let sortDir = -1;
let filteredData = [...CASES];
let nextId = CASES.length + 1;

// ─── GEO HELPERS ─────────────────────────────────────────────────────────
function buildGeoOptions() {
  const provinsiSel = document.getElementById('filterProvinsi');
  const unique = [...new Set(CASES.map(c => c.provinsi))].sort();
  unique.forEach(p => {
    const o = document.createElement('option');
    o.value = p; o.textContent = p;
    provinsiSel.appendChild(o);
  });
}

function onProvinsiChange() {
  const prov = document.getElementById('filterProvinsi').value;
  const kabSel = document.getElementById('filterKabupaten');
  const kecSel = document.getElementById('filterKecamatan');
  kabSel.innerHTML = '<option value="">Semua Kabupaten</option>';
  kecSel.innerHTML = '<option value="">Semua Kecamatan</option>';
  if (prov) {
    const kabs = [...new Set(CASES.filter(c => c.provinsi === prov).map(c => c.kabupaten))].sort();
    kabs.forEach(k => {
      const o = document.createElement('option');
      o.value = k; o.textContent = k;
      kabSel.appendChild(o);
    });
  }
  applyFilters();
}

function onKabupatenChange() {
  const prov = document.getElementById('filterProvinsi').value;
  const kab = document.getElementById('filterKabupaten').value;
  const kecSel = document.getElementById('filterKecamatan');
  kecSel.innerHTML = '<option value="">Semua Kecamatan</option>';
  if (kab) {
    const kecs = [...new Set(
      CASES.filter(c => (!prov || c.provinsi === prov) && c.kabupaten === kab && c.kecamatan !== '-')
        .map(c => c.kecamatan)
    )].sort();
    kecs.forEach(k => {
      const o = document.createElement('option');
      o.value = k; o.textContent = k;
      kecSel.appendChild(o);
    });
  }
  applyFilters();
}

// ─── FILTERS ──────────────────────────────────────────────────────────────
function applyFilters() {
  const search1 = (document.getElementById('searchInput').value || '').toLowerCase();
  const search2 = (document.getElementById('searchInput2').value || '').toLowerCase();
  const search = search1 || search2;
  const prov = document.getElementById('filterProvinsi').value;
  const kab = document.getElementById('filterKabupaten').value;
  const kec = document.getElementById('filterKecamatan').value;
  const dateFrom = document.getElementById('dateFrom').value;
  const dateTo = document.getElementById('dateTo').value;
  const minK = parseInt(document.getElementById('minKorban').value) || 0;

  filteredData = CASES.filter(c => {
    if (search && ![c.lokasi, c.provinsi, c.kabupaten, c.kecamatan, c.gejala, c.sumber].join(' ').toLowerCase().includes(search)) return false;
    if (prov && c.provinsi !== prov) return false;
    if (kab && c.kabupaten !== kab) return false;
    if (kec && c.kecamatan !== kec) return false;
    if (dateFrom && c.tanggal < dateFrom) return false;
    if (dateTo && c.tanggal > dateTo) return false;
    if (c.korban < minK) return false;
    return true;
  });

  sortData();
  updateStats();
  updateMap();
  render();
}

function resetFilters() {
  document.getElementById('searchInput').value = '';
  document.getElementById('searchInput2').value = '';
  document.getElementById('filterProvinsi').value = '';
  document.getElementById('filterKabupaten').value = '';
  document.getElementById('filterKecamatan').value = '';
  document.getElementById('filterKabupaten').innerHTML = '<option value="">Semua Kabupaten</option>';
  document.getElementById('filterKecamatan').innerHTML = '<option value="">Semua Kecamatan</option>';
  document.getElementById('dateFrom').value = '2025-01-01';
  document.getElementById('dateTo').value = '';
  document.getElementById('minKorban').value = '';
  applyFilters();
}

// ─── SORT ─────────────────────────────────────────────────────────────────
function sortData() {
  filteredData.sort((a, b) => {
    let va = a[sortField], vb = b[sortField];
    if (typeof va === 'string') return va.localeCompare(vb) * sortDir;
    return (va - vb) * sortDir;
  });
}

function setSort(field) {
  if (sortField === field) sortDir *= -1;
  else { sortField = field; sortDir = -1; }
  sortData();
  render();
}

// ─── STATS ────────────────────────────────────────────────────────────────
function updateStats() {
  const totalKorban = filteredData.reduce((s, c) => s + c.korban, 0);
  const totalRawat = filteredData.reduce((s, c) => s + c.rawatInap, 0);
  document.getElementById('statKasus').textContent = filteredData.length.toLocaleString('id-ID');
  document.getElementById('statKorban').textContent = totalKorban.toLocaleString('id-ID');
  document.getElementById('statRawat').textContent = totalRawat.toLocaleString('id-ID');
  document.getElementById('resultCount').textContent = `${filteredData.length} kasus ditemukan`;
}

// ─── RENDER ───────────────────────────────────────────────────────────────
function setView(v) {
  currentView = v;
  document.getElementById('btnCard').classList.toggle('active', v === 'card');
  document.getElementById('btnTable').classList.toggle('active', v === 'table');
  render();
}

function fmtDate(d) {
  const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
  const [y, m, day] = d.split('-');
  return `${parseInt(day)} ${months[parseInt(m)-1]} ${y}`;
}

function render() {
  const out = document.getElementById('casesOutput');
  if (filteredData.length === 0) {
    out.innerHTML = `<div class="empty-state"><div class="icon">🔍</div><p>Tidak ada kasus yang cocok dengan filter ini.<br>Coba ubah kriteria pencarian.</p></div>`;
    return;
  }
  if (currentView === 'card') renderCards(out);
  else renderTable(out);
}

function renderCards(out) {
  out.innerHTML = `<div class="cases-grid">${filteredData.map(c => `
    <div class="case-card ${c.isNew ? 'new-case' : ''}" onclick="openNews(${c.id})" title="Klik untuk cari berita: ${c.lokasi}">
      <div class="card-top">
        <div class="card-date">${fmtDate(c.tanggal)}</div>
        <div>
          ${c.isNew ? '<span class="badge badge-new">Baru</span>' : ''}
          ${c.isKLB ? '<span class="badge badge-klb">KLB</span>' : ''}
        </div>
      </div>
      <div class="card-lokasi">${c.lokasi}</div>
      <div class="card-geo">
        <span>${c.provinsi}</span>
        <span class="geo-sep">›</span>
        <span>${c.kabupaten}</span>
        ${c.kecamatan !== '-' ? `<span class="geo-sep">›</span><span>${c.kecamatan}</span>` : ''}
      </div>
      <div class="card-gejala">${c.gejala}</div>
      <div class="card-bottom">
        <div style="display:flex;gap:6px;flex-wrap:wrap">
          <span class="korban-chip">⚠ ${c.korban.toLocaleString('id-ID')} korban</span>
          ${c.rawatInap ? `<span class="rawat-chip">🏥 ${c.rawatInap} rawat inap</span>` : ''}
        </div>
        <span class="sumber-chip">${c.sumber}</span>
      </div>
    </div>`).join('')}</div>`;
}

function renderTable(out) {
  const cols = [
    { field:'tanggal', label:'Tanggal' },
    { field:'provinsi', label:'Provinsi' },
    { field:'kabupaten', label:'Kabupaten' },
    { field:'kecamatan', label:'Kecamatan' },
    { field:'lokasi', label:'Lokasi' },
    { field:'korban', label:'Korban' },
    { field:'gejala', label:'Gejala' },
    { field:'sumber', label:'Sumber' },
  ];
  out.innerHTML = `<div style="overflow-x:auto"><table class="cases-table">
    <thead><tr>${cols.map(c => `
      <th onclick="setSort('${c.field}')" class="${sortField===c.field?'sorted':''}">
        ${c.label} <span class="sort-icon">${sortField===c.field?(sortDir===1?'↑':'↓'):'↕'}</span>
      </th>`).join('')}</tr></thead>
    <tbody>${filteredData.map(c => `
      <tr onclick="openNews(${c.id})" title="Klik untuk cari berita: ${c.lokasi}">
        <td class="td-date">${fmtDate(c.tanggal)}</td>
        <td>${c.provinsi}</td>
        <td class="td-geo">${c.kabupaten}</td>
        <td class="td-geo">${c.kecamatan}</td>
        <td>
          ${c.isNew ? '<span class="badge badge-new" style="margin-right:5px">Baru</span>' : ''}
          ${c.isKLB ? '<span class="badge badge-klb" style="margin-right:5px">KLB</span>' : ''}
          ${c.lokasi}
        </td>
        <td class="td-korban">${c.korban.toLocaleString('id-ID')}</td>
        <td style="max-width:200px;font-size:12px;color:var(--muted)">${c.gejala}</td>
        <td style="font-size:11px;color:var(--muted2)">${c.sumber}</td>
      </tr>`).join('')}
    </tbody>
  </table></div>`;
}

// ─── OPEN NEWS IN NEW TAB ─────────────────────────────────────────────────
function openNews(id) {
  const c = CASES.find(x => x.id === id);
  if (!c) return;
  const q = `keracunan MBG ${c.lokasi} ${c.kabupaten} ${c.provinsi} ${c.tanggal.substring(0,7)}`;
  window.open(`https://www.google.com/search?q=${encodeURIComponent(q)}&tbm=nws`, '_blank');
}

function newsUrl(c) {
  const q = `keracunan MBG ${c.lokasi} ${c.kabupaten} ${c.provinsi} ${c.tanggal.substring(0,7)}`;
  return `https://www.google.com/search?q=${encodeURIComponent(q)}&tbm=nws`;
}

// ─── MAP ──────────────────────────────────────────────────────────────────
let _map = null;
let _heatLayer = null;
let _markersGroup = null;

function initMap() {
  if (!_map) {
    _map = L.map('mapContainer', { zoomControl:true }).setView([-2.5, 118], 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution:'© <a href="https://www.openstreetmap.org/copyright" style="color:#555">OpenStreetMap</a>',
      maxZoom:18
    }).addTo(_map);
  }
  updateMap();
}

function updateMap() {
  if (!_map) return;
  if (_heatLayer) { _map.removeLayer(_heatLayer); _heatLayer = null; }
  if (_markersGroup) { _map.removeLayer(_markersGroup); _markersGroup = null; }

  const withCoords = filteredData.filter(c => c.lat && c.lng);
  if (!withCoords.length) return;

  const maxK = Math.max(...withCoords.map(c => c.korban));

  // Heatmap layer
  const heatData = withCoords.map(c => [c.lat, c.lng, Math.max(0.1, c.korban / maxK)]);
  _heatLayer = L.heatLayer(heatData, {
    radius:52, blur:38, maxZoom:9, max:1.0,
    gradient:{0.2:'#4a9eff', 0.45:'#f5a623', 0.7:'#e3000f', 1.0:'#ff0000'}
  }).addTo(_map);

  // Circle markers
  _markersGroup = L.layerGroup();
  withCoords.forEach(c => {
    const r = Math.max(7, Math.min(26, Math.sqrt(c.korban) * 1.1));
    const marker = L.circleMarker([c.lat, c.lng], {
      radius: r,
      fillColor: c.isKLB ? '#f5a623' : '#e3000f',
      color: c.isKLB ? '#a07000' : '#7a0008',
      weight: 1.5,
      opacity: 0.9,
      fillOpacity: 0.55
    });
    marker.bindPopup(`
      <b>${c.lokasi}</b>
      <div class="pop-geo">${c.provinsi} › ${c.kabupaten}${c.kecamatan !== '-' ? ' › '+c.kecamatan : ''}</div>
      <div class="pop-korban">⚠ ${c.korban.toLocaleString('id-ID')} korban</div>
      <div class="pop-gejala">${c.gejala}</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted)">${fmtDate(c.tanggal)} · ${c.sumber}</div>
      <a class="pop-link" href="${newsUrl(c)}" target="_blank" rel="noopener">Cari Berita →</a>
    `, { maxWidth:260 });
    _markersGroup.addLayer(marker);
  });
  _markersGroup.addTo(_map);
  setTimeout(() => _map.invalidateSize(), 50);
}

// ─── AI REFRESH ──────────────────────────────────────────────────────────
function getLatestDate() {
  return CASES.reduce((max, c) => c.tanggal > max ? c.tanggal : max, '2025-01-01');
}

async function refreshWithAI() {
  const btn = document.getElementById('btnRefresh');
  const icon = document.getElementById('refreshIcon');
  const label = document.getElementById('refreshLabel');
  const aiStatus = document.getElementById('aiStatus');

  btn.disabled = true;
  btn.classList.add('loading');
  icon.textContent = '⟳';
  label.textContent = 'Mencari berita…';
  aiStatus.classList.add('show');

  showToast('info', '🤖 AI Aktif', 'Mencari berita keracunan MBG terbaru dari internet…');

  try {
    const latestDate = getLatestDate();
    const existingIds = CASES.map(c => `${c.tanggal}|${c.kabupaten}|${c.korban}`).join(', ');

    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 2000,
        tools: [{ type: "web_search_20250305", name: "web_search" }],
        messages: [{
          role: "user",
          content: `Cari berita terbaru hari ini tentang kasus keracunan MBG (Makan Bergizi Gratis) di Indonesia. Tanggal hari ini: ${new Date().toLocaleDateString('id-ID', {day:'numeric',month:'long',year:'numeric'})}.

Fokus pada kasus yang terjadi SETELAH tanggal ${latestDate}. Cari dengan keyword: "keracunan MBG", "keracunan Makan Bergizi Gratis", "siswa keracunan MBG 2026".

Kembalikan HANYA JSON valid tanpa penjelasan, tanpa markdown, langsung JSON:
{
  "kasus_baru": [
    {
      "tanggal": "YYYY-MM-DD",
      "provinsi": "nama provinsi lengkap",
      "kabupaten": "nama kabupaten/kota",
      "kecamatan": "nama kecamatan atau - jika tidak diketahui",
      "lokasi": "nama sekolah atau tempat spesifik",
      "korban": angka_integer,
      "rawatInap": angka_integer_atau_0,
      "gejala": "deskripsi gejala singkat",
      "sumber": "nama media",
      "isKLB": true_atau_false
    }
  ],
  "ringkasan": "1-2 kalimat ringkasan situasi terbaru"
}`
        }]
      })
    });

    if (!response.ok) throw new Error(`API error: ${response.status}`);
    const data = await response.json();

    // Extract text from all content blocks
    const textContent = (data.content || [])
      .filter(b => b.type === 'text')
      .map(b => b.text)
      .join('\n');

    // Parse JSON from response
    let parsed = null;
    const jsonMatch = textContent.match(/\{[\s\S]*\}/);
    if (jsonMatch) {
      try { parsed = JSON.parse(jsonMatch[0]); } catch(e) {}
    }

    if (parsed && parsed.kasus_baru && Array.isArray(parsed.kasus_baru)) {
      const newCases = parsed.kasus_baru.filter(nc => {
        // Deduplicate by date+kabupaten
        return !CASES.some(existing =>
          existing.tanggal === nc.tanggal &&
          existing.kabupaten?.toLowerCase() === nc.kabupaten?.toLowerCase()
        );
      });

      if (newCases.length > 0) {
        newCases.forEach(nc => {
          CASES.unshift({
            id: nextId++,
            tanggal: nc.tanggal || new Date().toISOString().split('T')[0],
            provinsi: nc.provinsi || '-',
            kabupaten: nc.kabupaten || '-',
            kecamatan: nc.kecamatan || '-',
            lokasi: nc.lokasi || '-',
            korban: parseInt(nc.korban) || 0,
            rawatInap: parseInt(nc.rawatInap) || 0,
            gejala: nc.gejala || '-',
            sumber: nc.sumber || 'AI Search',
            isNew: true,
            isKLB: !!nc.isKLB
          });
        });

        // Rebuild geo dropdowns
        rebuildGeo();
        applyFilters();
        showToast('success', `✅ ${newCases.length} Kasus Baru Ditemukan`, parsed.ringkasan || 'Data berhasil diperbarui dari pencarian berita terkini.');
      } else {
        showToast('info', '✓ Data Sudah Terkini', parsed.ringkasan || 'Tidak ada kasus baru yang ditemukan setelah pencarian berita terkini.');
        applyFilters();
      }
    } else {
      showToast('info', '✓ Pencarian Selesai', 'AI tidak menemukan kasus baru yang dapat diverifikasi saat ini.');
    }

  } catch (err) {
    console.error(err);
    showToast('error', '⚠ Gagal Memperbarui', `Terjadi kesalahan: ${err.message}. Coba lagi beberapa saat.`);
  } finally {
    btn.disabled = false;
    btn.classList.remove('loading');
    icon.textContent = '⟳';
    label.textContent = 'Perbarui dengan AI';
    aiStatus.classList.remove('show');
  }
}

function rebuildGeo() {
  const provinsiSel = document.getElementById('filterProvinsi');
  const savedProv = provinsiSel.value;
  provinsiSel.innerHTML = '<option value="">Semua Provinsi</option>';
  const unique = [...new Set(CASES.map(c => c.provinsi))].sort();
  unique.forEach(p => {
    const o = document.createElement('option');
    o.value = p; o.textContent = p;
    provinsiSel.appendChild(o);
  });
  if (savedProv) provinsiSel.value = savedProv;
}

// ─── TOAST ───────────────────────────────────────────────────────────────
function showToast(type, title, msg) {
  const container = document.getElementById('toastContainer');
  const icons = { success:'✅', error:'❌', info:'ℹ️' };
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `<div class="toast-icon">${icons[type]||'•'}</div><div class="toast-body"><div class="toast-title">${title}</div><div class="toast-msg">${msg}</div></div>`;
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.animation = 'slideIn .3s ease reverse both';
    setTimeout(() => toast.remove(), 350);
  }, 5000);
}

// ─── INIT ─────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('dateTo').max = new Date().toISOString().split('T')[0];
  buildGeoOptions();
  currentView = 'card';
  applyFilters();
  initMap();
});
</script>
</body>
</html>
